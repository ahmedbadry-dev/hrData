{
  "name": "server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc --project tsconfig.json",
    "start": "node dist/main.js",
    "type-check": "tsc --noEmit",
    "db:seed": "npx prisma db seed",
    "prisma:studio": "npx prisma studio",
    "test": "tsx --test \"tests/**/*.test.ts\"",
    "test:watch": "tsx --test --watch \"tests/**/*.test.ts\""
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^6.19.3",
    "axios": "1.15.0",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.73.1",
    "cheerio": "^1.2.0",
    "cookie-parser": "^1.4.7",
    "cors": "latest",
    "dotenv": "latest",
    "express": "latest",
    "groq-sdk": "^1.1.2",
    "helmet": "latest",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "morgan": "latest",
    "nodemailer": "^8.0.5",
    "openai": "^6.34.0",
    "p-limit": "^3.1.0",
    "pg": "^8.20.0",
    "ua-parser-js": "^2.0.9",
    "uuid": "^13.0.0",
    "winston": "^3.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "latest",
    "@types/express": "latest",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "latest",
    "@types/node": "latest",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.20.0",
    "@types/uuid": "^10.0.0",
    "prisma": "^6.19.3",
    "tsx": "latest",
    "typescript": "latest"
  }
}
