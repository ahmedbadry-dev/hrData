    "nodemailer": "^8.0.5",
    "uuid": "^13.0.0",
    "winston": "^3.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "latest",
    "@types/express": "latest",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "latest",
    "@types/node": "latest",
    "@types/nodemailer": "^8.0.0",
