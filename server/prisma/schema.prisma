  RIYADH
  AL_KHARJ
  AL_DAWADIMI
  AL_MAJMAAH
  AL_QUWAYIYAH
  WADI_AD_DAWASIR
  AL_AFLAJ
  AL_ZULFI
  SHAQRA
  AFIF
  AS_SULAYYIL
  MECCA
  JEDDAH
  TAIF
  AL_QUNFUDHAH
  RABIGH
  AL_LAYTH
  KHULAIS
  MEDINA
  YANBU
  AL_ULA
  MAHAD_AD_DAHAB
  BADR
  KHAYBAR
  BURAYDAH
  UNAIZAH
  AL_RASS
  AL_MITHNAB
  ASH_SHAMASIYAH
  DAMMAM
  KHOBAR
  AL_AHSA
  JUBAIL
  QATIF
  HAFR_AL_BATIN
  AL_KHAFJI
  ABHA
  KHAMIS_MUSHAIT
  BISHA
  AL_NAMAS
  MAHAYIL_ASIR
  TABUK
  DUBA
  TAYMA
  AL_WAJH
  UMLUJ
  HAIL
  BAQAA
  AL_GHAZALAH
  SAMIRA
  ARAR
  RAFHA
  TURAIF
  JIZAN
  SABYA
  ABU_ARISH
  SAMTAH
  BAISH
  NAJRAN
  SHARURAH
  BAHA
  BALJURASHI
  AL_MAKHWAH
  SAKAKA
  DUMAT_AL_JANDAL
  QURAYYAT
  OTHER
}

enum DateFilter {
  DAY
  WEEK
  MONTH
}

enum JobQualification {
  HIGH_SCHOOL
  DIPLOMA
  BACHELOR
  MASTER
  PHD
  OTHER
}

enum JobSpecialization {
  ENGINEERING
  INFORMATION_TECHNOLOGY
  BUSINESS_ADMINISTRATION
  ACCOUNTING_FINANCE
  MARKETING_SALES
  HEALTHCARE
  EDUCATION
  HUMAN_RESOURCES
  OTHER
}

enum LanguageLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  FLUENT
  NATIVE
}

model User {
  id                         String     @id @default(uuid())
  firstName                  String     @map("first_name")
  lastName                   String     @map("last_name")
  email                      String     @unique
  phone                      String?    @unique @map("phone")
  passwordHash               String     @map("password_hash")
  role                       UserRole   @default(USER)
  status                     UserStatus @default(PENDING_VERIFICATION)
  dailyEmailLimit            Int        @default(50) @map("daily_email_limit")
  limitReachedAt             DateTime?  @map("limit_reached_at")
  lastQuotaResetAt           DateTime?  @map("last_quota_reset_at")
  emailVerified              Boolean    @default(false) @map("email_verified")
  verificationToken          String?    @map("verification_token")
  verificationTokenExpiresAt DateTime?  @map("verification_token_expires_at")
  resetToken                 String?    @map("reset_token")
  resetTokenExpiresAt        DateTime?  @map("reset_token_expires_at")
  failedLoginAttempts        Int        @default(0) @map("failed_login_attempts")
  lockedUntil                DateTime?  @map("locked_until")
  createdAt                  DateTime   @default(now()) @map("created_at")
  updatedAt                  DateTime   @updatedAt @map("updated_at")

  gmailTokens   GmailToken[]
  savedJobs     SavedJob[]
  applications  Application[]
  notifications Notification[]
  activityLogs  ActivityLog[]
  profile       UserProfile?
  experiences   UserExperience[]
  skills        UserSkill[]
  languages     UserLanguage[]
  quotaResets   UserQuotaReset[] @relation("QuotaResetsForUser")
  quotaResetBy  UserQuotaReset[] @relation("QuotaResetsByAdmin")

  @@map("users")
}

model UserQuotaReset {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  resetById String?  @map("reset_by_id")
  reason    String
  createdAt DateTime @default(now()) @map("created_at")

  user    User  @relation("QuotaResetsForUser", fields: [userId], references: [id], onDelete: Cascade)
  resetBy User? @relation("QuotaResetsByAdmin", fields: [resetById], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([resetById, createdAt])
  @@map("user_quota_resets")
}

model UserProfile {
  id             String             @id @default(uuid())
  userId         String             @unique @map("user_id")
  summary        String?
  qualification  JobQualification?
  specialization JobSpecialization?
  institution    String?
  graduationYear Int?               @map("graduation_year")
  createdAt      DateTime           @default(now()) @map("created_at")
  updatedAt      DateTime           @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

model UserExperience {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  jobTitle    String    @map("job_title")
  company     String
  startDate   DateTime  @map("start_date")
  endDate     DateTime? @map("end_date")
  description String?
  sortOrder   Int       @default(0) @map("sort_order")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, sortOrder])
  @@map("user_experiences")
}

model UserSkill {
  id             String   @id @default(uuid())
  userId         String   @map("user_id")
  name           String
  normalizedName String   @map("normalized_name")
  sortOrder      Int      @default(0) @map("sort_order")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, normalizedName])
  @@index([userId, sortOrder])
  @@map("user_skills")
}

model UserLanguage {
  id             String        @id @default(uuid())
  userId         String        @map("user_id")
  name           String
  normalizedName String        @map("normalized_name")
  level          LanguageLevel
  sortOrder      Int           @default(0) @map("sort_order")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, normalizedName])
  @@index([userId, sortOrder])
  @@map("user_languages")
}

model GmailToken {
  id           String   @id @default(uuid())
  userId       String   @unique @map("user_id")
  accessToken  String   @map("access_token")
  refreshToken String   @map("refresh_token")
  tokenExpiry  DateTime @map("token_expiry")
  email        String
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("gmail_tokens")
}

model Job {
  id                  String            @id @default(uuid())
  title               String
  companyName         String            @map("company_name")
  location            JobLocation?      @default(OTHER)
  category            String?
  description         String?
  hrEmail             String?           @map("hr_email")
  source              String
  sourceUrl           String?           @map("source_url")
  experience          String?
  languageRequirement String?           @map("language_requirement")
  language            String            @default("ar")
  postedAt            DateTime?         @map("posted_at")
  expiresAt           DateTime?         @map("expires_at")
  isExpired           Boolean           @default(false) @map("is_expired")
  qualification       JobQualification  @default(OTHER)
  specialization      JobSpecialization @default(OTHER)
  createdAt           DateTime          @default(now()) @map("created_at")
  updatedAt           DateTime          @updatedAt @map("updated_at")

  savedJobs    SavedJob[]
  applications Application[]

  @@unique([title, companyName, location])
  @@map("jobs")
}

model SavedJob {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  jobId     String   @map("job_id")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  job  Job  @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([userId, jobId])
  @@map("saved_jobs")
}

model Application {
  id            String            @id @default(uuid())
  userId        String            @map("user_id")
  jobId         String            @map("job_id")
  status        ApplicationStatus @default(SCHEDULED)
  scheduledAt   DateTime?         @map("scheduled_at")
  sentAt        DateTime?         @map("sent_at")
  openedAt      DateTime?         @map("opened_at")
  trackingToken String?           @unique @map("tracking_token")
  errorMessage  String?           @map("error_message")
  retryCount    Int               @default(0) @map("retry_count")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  job  Job  @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([userId, status, createdAt])
  @@map("applications")
}

model Notification {
  id        String             @id @default(uuid())
  userId    String?            @map("user_id")
  title     String
  body      String
  type      NotificationType   @default(INFO)
  target    NotificationTarget @default(USER)
  isRead    Boolean            @default(false) @map("is_read")
  createdAt DateTime           @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model ActivityLog {
  id         String   @id @default(uuid())
  userId     String?  @map("user_id")
  action     String
  entityType String?  @map("entity_type")
  entityId   String?  @map("entity_id")
  metadata   Json?    @map("metadata")
  ipAddress  String?  @map("ip_address")
  createdAt  DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("activity_logs")
}

model ScrapedLog {
  id           String   @id @default(uuid())
  siteName     String   @map("site_name")
  linksFound   Int      @default(0) @map("links_found")
  jobsScraped  Int      @default(0) @map("jobs_scraped")
  status       String   @default("SUCCESS")
  errorMessage String?  @map("error_message")
  duration     Int?     @map("duration_ms")
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("scraped_logs")
}

model SystemSetting {
  id          String   @id @default(uuid())
  key         String   @unique
  value       String
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("system_settings")
}
