generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  // just to run prisma studio
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
  SUPER_ADMIN
}

enum UserStatus {
  PENDING_VERIFICATION
  ACTIVE
  SUSPENDED
}

enum ApplicationStatus {
  SCHEDULED
  SENDING
  SENT
  FAILED
  EMAIL_OPENED
}

enum NotificationType {
  INFO
  SUCCESS
  WARNING
  ALERT
}

enum NotificationTarget {
  ALL
  ADMIN
  USER
}

model User {
  id                         String     @id @default(uuid())
  firstName                  String     @map("first_name")
  lastName                   String     @map("last_name")
  email                      String     @unique
  phone                      String?    @unique @map("phone")
  passwordHash               String     @map("password_hash")
  role                       UserRole   @default(USER)
  status                     UserStatus @default(PENDING_VERIFICATION)
  emailVerified              Boolean    @default(false) @map("email_verified")
  verificationToken          String?    @map("verification_token")
  verificationTokenExpiresAt DateTime?  @map("verification_token_expires_at")
  resetToken                 String?    @map("reset_token")
  resetTokenExpiresAt        DateTime?  @map("reset_token_expires_at")
  failedLoginAttempts        Int        @default(0) @map("failed_login_attempts")
  lockedUntil                DateTime?  @map("locked_until")
  createdAt                  DateTime   @default(now()) @map("created_at")
  updatedAt                  DateTime   @updatedAt @map("updated_at")

  sessions       Session[]
  gmailTokens    GmailToken[]
  savedJobs      SavedJob[]
  cvs            Cv[]
  emailTemplates EmailTemplate[]
  applications   Application[]
  notifications  Notification[]
  activityLogs   ActivityLog[]

  @@map("users")
}

model Session {
  id        String   @id
  userId    String   @map("user_id")
  tokenHash String   @unique @map("token_hash")
  expiresAt DateTime @map("expires_at")
  deviceName String?  @map("device_name")
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model GmailToken {
  id           String   @id @default(uuid())
  userId       String   @unique @map("user_id")
  accessToken  String   @map("access_token")
  refreshToken String   @map("refresh_token")
  tokenExpiry  DateTime @map("token_expiry")
  email        String
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("gmail_tokens")
}

model Job {
  id          String    @id @default(uuid())
  title       String
  companyName String    @map("company_name")
  location    String?
  category    String?
  description String?
  hrEmail     String?   @map("hr_email")
  source      String
  sourceUrl   String?   @map("source_url")
  language    String    @default("ar")
  postedAt    DateTime? @map("posted_at")
  expiresAt   DateTime? @map("expires_at")
  isExpired   Boolean   @default(false) @map("is_expired")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  savedJobs    SavedJob[]
  applications Application[]

  @@unique([title, companyName, location])
  @@map("jobs")
}

model SavedJob {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  jobId     String   @map("job_id")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  job  Job  @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([userId, jobId])
  @@map("saved_jobs")
}

model Cv {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  fileName  String   @map("file_name")
  fileUrl   String   @map("file_url")
  fileSize  Int      @map("file_size")
  isDefault Boolean  @default(false) @map("is_default")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  applications Application[]

  @@map("cvs")
}

model EmailTemplate {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  name      String
  subject   String
  body      String
  isDefault Boolean  @default(false) @map("is_default")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  applications Application[]

  @@map("email_templates")
}

model Application {
  id              String            @id @default(uuid())
  userId          String            @map("user_id")
  jobId           String            @map("job_id")
  cvId            String?           @map("cv_id")
  emailTemplateId String?           @map("email_template_id")
  status          ApplicationStatus @default(SCHEDULED)
  scheduledAt     DateTime?         @map("scheduled_at")
  sentAt          DateTime?         @map("sent_at")
  openedAt        DateTime?         @map("opened_at")
  trackingToken   String?           @unique @map("tracking_token")
  errorMessage    String?           @map("error_message")
  retryCount      Int               @default(0) @map("retry_count")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  job           Job            @relation(fields: [jobId], references: [id], onDelete: Cascade)
  cv            Cv?            @relation(fields: [cvId], references: [id], onDelete: SetNull)
  emailTemplate EmailTemplate? @relation(fields: [emailTemplateId], references: [id], onDelete: SetNull)

  @@map("applications")
}

model Notification {
  id        String             @id @default(uuid())
  userId    String?            @map("user_id")
  title     String
  body      String
  type      NotificationType   @default(INFO)
  target    NotificationTarget @default(USER)
  isRead    Boolean            @default(false) @map("is_read")
  createdAt DateTime           @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model ActivityLog {
  id         String   @id @default(uuid())
  userId     String?  @map("user_id")
  action     String
  entityType String?  @map("entity_type")
  entityId   String?  @map("entity_id")
  metadata   Json?    @map("metadata")
  ipAddress  String?  @map("ip_address")
  createdAt  DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("activity_logs")
}

model SystemSetting {
  id          String   @id @default(uuid())
  key         String   @unique
  value       String
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("system_settings")
}
