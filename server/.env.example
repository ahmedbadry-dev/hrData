# ======================
# APPLICATION
# ======================
NODE_ENV=development
PORT=5000
API_VERSION=v1
APP_URL=http://localhost:5173
SERVER_URL=http://localhost:5000
API_URL=http://localhost:5000

# ======================
# DATABASE
# ======================
DATABASE_URL=postgresql://postgres:replace-with-strong-password@localhost:5432/kafoo
DATABASE_NAME=kafoo

# ======================
# REDIS
# ======================
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_PASSWORD=
REDIS_URL=

# ======================
# JWT (min 32 chars each)
# ======================
JWT_ACCESS_SECRET=replace-with-random-32-plus-char-secret
JWT_REFRESH_SECRET=replace-with-random-32-plus-char-secret
JWT_VERIFICATION_TEMP_SECRET=replace-with-random-32-plus-char-secret
JWT_ACCESS_EXPIRES_IN=30m
JWT_REFRESH_EXPIRES_IN=7d
JWT_VERIFICATION_EXPIRES_IN=24h

# ======================
# ENCRYPTION (64-char hex)
# ======================
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# ======================
# EMAIL (SMTP)
# ======================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-smtp-app-password
EMAIL_FROM=your-email@example.com
TEST_HR_EMAIL=your-email@example.com
SMTP_ALLOW_SELF_SIGNED_TLS=false

# ======================
# GMAIL OAUTH
# ======================
GMAIL_OAUTH_CLIENT_ID=
GMAIL_OAUTH_CLIENT_SECRET=
GMAIL_OAUTH_REDIRECT_URI=http://localhost:5000/api/v1/gmail/callback
GMAIL_OAUTH_SCOPE=openid email profile https://www.googleapis.com/auth/gmail.send
GMAIL_OAUTH_STATE_SECRET=replace-with-random-hex-32

# ======================
# LLM & AI
# ======================
GEMINI_API_KEY=
OPEN_ROUTER_API_KEY=
LLM_BASE_URL=

# ======================
# EXTERNAL APIS
# ======================
GETXAPI_KEY=

# ======================
# CORS
# ======================
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173
