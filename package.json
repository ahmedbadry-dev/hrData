{
  "name": "pern-monorepo",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=server\" \"npm run dev --workspace=client\"",
    "build": "npm run build --workspace=server && npm run build --workspace=client",
    "lint": "prettier --check \"**/*.{ts,tsx,js,json,md}\"",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\"",
    "pretype:check": "npm run prisma:generate --workspace=server",
    "type:check": "npm run type:check --workspace=server && npm run type:check --workspace=client"
  },
  "devDependencies": {
    "concurrently": "latest",
    "cross-env": "^10.1.0",
    "prettier": "latest"
  }
}
